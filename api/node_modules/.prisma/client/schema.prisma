generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model professor {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String

  turma turma[]
}

model turma {
  id          Int    @id @default(autoincrement())
  nome        String
  professorId Int

  professor professor @relation(fields: [professorId], references: [id])

  atividade atividade[]
}

model atividade {
  id        Int      @id @default(autoincrement())
  descricao String
  turmaId   Int
  iniciada  DateTime @default(now())
  termino   DateTime

  turma turma @relation(fields: [turmaId], references: [id])
}
